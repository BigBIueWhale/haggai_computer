#!/bin/bash
# Run the extracted T3 Code AppImage as a regular KDE application. Electron's
# user-namespace sandbox is unavailable in this container; the container itself
# is the isolation boundary, matching Chrome and VS Code above.
set -euo pipefail
APPDIR=/opt/t3-code
export PATH="$APPDIR:$APPDIR/usr/sbin:$PATH"
export LD_LIBRARY_PATH="$APPDIR/usr/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
export XDG_DATA_DIRS="$APPDIR/usr/share:/usr/local/share:/usr/share${XDG_DATA_DIRS:+:$XDG_DATA_DIRS}"
export GSETTINGS_SCHEMA_DIR="$APPDIR/usr/share/glib-2.0/schemas${GSETTINGS_SCHEMA_DIR:+:$GSETTINGS_SCHEMA_DIR}"
exec "$APPDIR/t3code" --no-sandbox "$@"
